rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminUserDoc(userId) {
      return exists(/databases/(default)/documents/users/$(userId))
        && get(/databases/(default)/documents/users/$(userId)).data.role == "admin"
        && (
          get(/databases/(default)/documents/users/$(userId)).data.status == "approved"
          || get(/databases/(default)/documents/users/$(userId)).data.status == "active"
        )
        && get(/databases/(default)/documents/users/$(userId)).data.suspended != true;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true
        || isAdminUserDoc(request.auth.uid)
      );
    }

    function isImageUnder5Mb() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isReceiptUnder10Mb() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    // Public reads for app assets (images shown on landing/dashboard).
    // Writes are restricted by path.
    match /profiles/{uid}/{allPaths=**} {
      allow read: if true;
      allow delete: if signedIn() && request.auth.uid == uid;
      allow create, update: if signedIn() && request.auth.uid == uid && isImageUnder5Mb();
    }

    match /post-images/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid && isImageUnder5Mb();
    }

    match /carousel/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImageUnder5Mb();
    }

    match /partners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImageUnder5Mb();
    }

    match /event-images/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImageUnder5Mb();
    }

    match /fixture-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImageUnder5Mb();
    }

    // Issue report screenshots (private to reporter + admins)
    match /issue-reports/{uid}/{allPaths=**} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow write: if signedIn() && request.auth.uid == uid && isImageUnder5Mb();
    }

    // Receipts (financial records)
    // Store receipts under the uploader's uid. Admins can read all receipts.
    match /receipts/{uid}/{allPaths=**} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow write: if signedIn() && request.auth.uid == uid && isReceiptUnder10Mb();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

